# ---------------------------------------------------------------------------
# WeatherGuard API — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# App
PORT=3000
NODE_ENV=development
# Public URL of this API (used to build OAuth callback URLs)
API_URL=http://localhost:3000
# URL of the deployed admin/web frontend (used for post-login redirects & CORS)
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/weatherguard

# Redis (BullMQ job queue — use a free Upstash/Redis Cloud instance in production)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma separated list of emails that are auto-approved as admins on first login.
# This is how you "seed" your first administrator — no manual DB editing needed.
ADMIN_EMAILS=you@example.com

# Google OAuth (console.cloud.google.com -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth (github.com/settings/developers -> OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Telegram (message @BotFather on Telegram to create a bot and get a token)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=WeatherGuardAlertsBot

# Weather (optional — free tier key from openweathermap.org).
# If omitted, the WeatherService falls back to a deterministic simulated
# forecast so the whole pipeline still works end-to-end without any key.
OPENWEATHER_API_KEY=

# Cron expression for the recurring alert broadcast (default: every hour)
ALERT_BROADCAST_CRON=0 * * * *
